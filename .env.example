# Agent Core configuration
# Copy this file to .env and adjust values for your environment.

# Server
AGENT_CORE_PORT=3500
AGENT_CORE_DATA_PATH=./data

# Encryption
# "auto" creates the data directory encryption key on first use.
# To provide your own key, generate a Fernet key and set it here.
AGENT_CORE_ENCRYPTION_KEY=auto

# Sessions
AGENT_CORE_SESSION_DURATION_HOURS=8
AGENT_CORE_INACTIVITY_TIMEOUT_MINUTES=30
# Set true when serving Agent Core over HTTPS so browser session cookies use the Secure flag.
AGENT_CORE_COOKIE_SECURE=false

# Trusted reverse proxy IPs whose X-Forwarded-For header may be used for login rate-limit identity.
AGENT_CORE_TRUSTED_PROXIES=

# Agent defaults
# Comma-separated normalized agent IDs that may write to shared scope.
AGENT_CORE_SHARED_SCOPE_AGENTS=

# Activity stale threshold in minutes.
AGENT_CORE_STALE_THRESHOLD_MINUTES=5

# CORS. Leave empty for wildcard origins without credentialed CORS.
# Set explicit origins to enable credentialed browser requests.
AGENT_CORE_CORS_ORIGINS=

# IP allowlist. Empty means allow all.
# Example: AGENT_CORE_ALLOWED_IPS=127.0.0.1,10.0.0.0/8,192.168.1.0/24
AGENT_CORE_ALLOWED_IPS=

# Internal host allowlist for trusted connector targets.
# Private/loopback/link-local connector targets are allowed by default for local deployments.
# Set this to true to block them unless the host is listed in AGENT_CORE_ALLOWED_INTERNAL_HOSTS.
AGENT_CORE_BLOCK_INTERNAL_HOSTS=false
# Use this for operator-managed services such as local Firecrawl or SearXNG deployments.
# Example: AGENT_CORE_ALLOWED_INTERNAL_HOSTS=firecrawl,searxng
AGENT_CORE_ALLOWED_INTERNAL_HOSTS=

# MCP tool-result offloading. Large tool responses are stored in the DB and returned as a handle.
AGENT_CORE_TOOL_RESULT_SPILL_THRESHOLD=8000
AGENT_CORE_TOOL_RESULT_SPILL_TTL_HOURS=24
