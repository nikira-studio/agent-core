{
  "spec_version": "1.0",
  "id": "lifequery",
  "display_name": "LifeQuery",
  "version": "1.0.0",
  "author": "agent-core team",
  "description": "LifeQuery Agent API — read-only retrieval and summaries over your self-hosted Telegram memory engine. List chats and people, pull messages or chunked context by date range and filters, and generate LLM summaries. All actions are read-only.",
  "setup": {
    "instructions": "Connect Agent Core to a self-hosted LifeQuery install.\n\n1. Run LifeQuery and confirm its Agent API is up: GET {base_url}/api/health returns 200.\n2. In LifeQuery Settings, set an API Key (strongly recommended). The same key guards the agent endpoints and the OpenAI-compatible /v1 API. If no key is configured LifeQuery allows access, but do not expose the raw-message endpoints outside a trusted network without one.\n3. Create the binding:\n   - base_url: the LifeQuery backend root only, e.g. http://lifequery-host:3134 (host) or http://backend:8000 if Agent Core shares LifeQuery's Docker network. Do NOT include /api/agent — each action appends its own path.\n   - api_token: the LifeQuery API Key from step 2. For a local instance with no key configured, any placeholder works (LifeQuery ignores the header when no key is set).\n\nNote: Agent Core blocks private/loopback base_url values (localhost, 127.0.0.1, 172.x, etc.) unless that host is on the internal-host allowlist. For a same-host LifeQuery, allowlist its address or reach it over a proxied/public hostname.",
    "documentation_url": "https://github.com/nikira-studio/lifequery/blob/main/docs/AGENT_API.md"
  },
  "credential_schema": {
    "fields": [
      {
        "name": "api_token",
        "type": "string",
        "secret": true,
        "required": true,
        "description": "LifeQuery API Key (Settings → API Key). Sent as a Bearer token."
      }
    ]
  },
  "requires": { "config": ["base_url"] },
  "actions": [
    {
      "name": "list_chats",
      "description": "List chats, groups, and channels known to LifeQuery — use to resolve chat ids/names for filters.",
      "side_effect": "read",
      "input_schema": {
        "type": "object",
        "properties": {
          "included_only": {
            "type": "boolean",
            "description": "Only chats currently enabled in LifeQuery."
          },
          "chat_type": {
            "type": "string",
            "enum": ["private", "group", "channel"],
            "description": "Restrict to a single chat type."
          },
          "limit": {
            "type": "integer",
            "description": "Maximum number of chats to return."
          }
        }
      }
    },
    {
      "name": "list_people",
      "description": "List known senders/people — use to resolve sender ids/names for filters.",
      "side_effect": "read",
      "input_schema": {
        "type": "object",
        "properties": {
          "search": {
            "type": "string",
            "description": "Case-insensitive substring filter over person names."
          },
          "included_only": {
            "type": "boolean",
            "description": "Only people from chats currently enabled in LifeQuery."
          },
          "limit": {
            "type": "integer",
            "description": "Maximum number of people to return."
          }
        }
      }
    },
    {
      "name": "query_messages",
      "description": "Pull raw messages within a date range, optionally filtered by chat, sender, type, source, and text. Returns messages, count, and next_cursor for pagination.",
      "side_effect": "read",
      "input_schema": {
        "type": "object",
        "properties": {
          "start": {
            "type": "string",
            "description": "Inclusive start timestamp (ISO 8601, e.g. 2026-06-01T00:00:00Z)."
          },
          "end": {
            "type": "string",
            "description": "Exclusive end timestamp (ISO 8601)."
          },
          "chat_ids": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Restrict to these chat IDs."
          },
          "chat_names": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Restrict to these exact chat names."
          },
          "chat_types": {
            "type": "array",
            "items": { "type": "string", "enum": ["private", "group", "channel"] },
            "description": "Restrict to these chat types."
          },
          "sender_ids": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Restrict to these sender IDs."
          },
          "sender_names": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Restrict to these exact sender names."
          },
          "sources": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Restrict to these source values."
          },
          "included_only": {
            "type": "boolean",
            "description": "Only chats currently enabled in LifeQuery (default true)."
          },
          "text_query": {
            "type": "string",
            "description": "Case-insensitive substring filter over message text."
          },
          "limit": {
            "type": "integer",
            "description": "Maximum number of messages to return (default 500)."
          },
          "cursor": {
            "type": "string",
            "description": "Opaque pagination cursor from a previous response's next_cursor."
          },
          "order": {
            "type": "string",
            "enum": ["asc", "desc"],
            "description": "Sort order (default asc)."
          }
        },
        "required": ["start", "end"]
      }
    },
    {
      "name": "query_chunks",
      "description": "Pull chunked conversation context within a date range, optionally filtered by chat, participant, and text. Returns chunks, count, and next_cursor.",
      "side_effect": "read",
      "input_schema": {
        "type": "object",
        "properties": {
          "start": {
            "type": "string",
            "description": "Inclusive start timestamp (ISO 8601)."
          },
          "end": {
            "type": "string",
            "description": "Exclusive end timestamp (ISO 8601)."
          },
          "chat_ids": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Restrict to these chat IDs."
          },
          "chat_names": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Restrict to these exact chat names."
          },
          "chat_types": {
            "type": "array",
            "items": { "type": "string", "enum": ["private", "group", "channel"] },
            "description": "Restrict to these chat types."
          },
          "sender_names": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Restrict to chunks with these participant names."
          },
          "included_only": {
            "type": "boolean",
            "description": "Only chats currently enabled in LifeQuery (default true)."
          },
          "text_query": {
            "type": "string",
            "description": "Case-insensitive substring filter over chunk content."
          },
          "limit": {
            "type": "integer",
            "description": "Maximum number of chunks to return (default 100)."
          },
          "cursor": {
            "type": "string",
            "description": "Opaque pagination cursor from a previous response's next_cursor."
          },
          "order": {
            "type": "string",
            "enum": ["asc", "desc"],
            "description": "Sort order (default asc)."
          },
          "include_content": {
            "type": "boolean",
            "description": "Include chunk content in the response (default true)."
          }
        },
        "required": ["start", "end"]
      }
    },
    {
      "name": "summarize_range",
      "description": "Generate an LLM summary over messages within a date range and filters. Returns the summary text, message_count, and optionally the source messages.",
      "side_effect": "read",
      "input_schema": {
        "type": "object",
        "properties": {
          "start": {
            "type": "string",
            "description": "Inclusive start timestamp (ISO 8601)."
          },
          "end": {
            "type": "string",
            "description": "Exclusive end timestamp (ISO 8601)."
          },
          "chat_ids": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Restrict to these chat IDs."
          },
          "chat_names": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Restrict to these exact chat names."
          },
          "chat_types": {
            "type": "array",
            "items": { "type": "string", "enum": ["private", "group", "channel"] },
            "description": "Restrict to these chat types."
          },
          "sender_ids": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Restrict to these sender IDs."
          },
          "sender_names": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Restrict to these exact sender names."
          },
          "sources": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Restrict to these source values."
          },
          "included_only": {
            "type": "boolean",
            "description": "Only chats currently enabled in LifeQuery (default true)."
          },
          "text_query": {
            "type": "string",
            "description": "Case-insensitive substring filter over message text."
          },
          "limit": {
            "type": "integer",
            "description": "Maximum messages to feed the summary (default 1000)."
          },
          "cursor": {
            "type": "string",
            "description": "Opaque pagination cursor from a previous response's next_cursor."
          },
          "order": {
            "type": "string",
            "enum": ["asc", "desc"],
            "description": "Sort order (default asc)."
          },
          "prompt": {
            "type": "string",
            "description": "Optional extra instruction for the summary, e.g. focus areas."
          },
          "include_messages": {
            "type": "boolean",
            "description": "Include the source messages used for the summary (default false)."
          }
        },
        "required": ["start", "end"]
      }
    }
  ],
  "backend": {
    "type": "http",
    "base_url": { "from": "config", "field": "base_url" },
    "auth": { "type": "bearer" },
    "test_action": "list_chats",
    "requests": {
      "list_chats": {
        "method": "GET",
        "path": "/api/agent/chats",
        "query_params": {
          "included_only": "{{ params.included_only | default('', as=omit) }}",
          "chat_type": "{{ params.chat_type | default('', as=omit) }}",
          "limit": "{{ params.limit | default('', as=omit) }}"
        },
        "response": {
          "success_when": "$.status >= 200 and $.status < 300"
        }
      },
      "list_people": {
        "method": "GET",
        "path": "/api/agent/people",
        "query_params": {
          "search": "{{ params.search | default('', as=omit) }}",
          "included_only": "{{ params.included_only | default('', as=omit) }}",
          "limit": "{{ params.limit | default('', as=omit) }}"
        },
        "response": {
          "success_when": "$.status >= 200 and $.status < 300"
        }
      },
      "query_messages": {
        "method": "POST",
        "path": "/api/agent/messages/query",
        "body": {
          "template": {
            "start": "{{ params.start }}",
            "end": "{{ params.end }}",
            "chat_ids": "{{ params.chat_ids | default('', as=omit) }}",
            "chat_names": "{{ params.chat_names | default('', as=omit) }}",
            "chat_types": "{{ params.chat_types | default('', as=omit) }}",
            "sender_ids": "{{ params.sender_ids | default('', as=omit) }}",
            "sender_names": "{{ params.sender_names | default('', as=omit) }}",
            "sources": "{{ params.sources | default('', as=omit) }}",
            "included_only": "{{ params.included_only | default('', as=omit) }}",
            "text_query": "{{ params.text_query | default('', as=omit) }}",
            "limit": "{{ params.limit | default('', as=omit) }}",
            "cursor": "{{ params.cursor | default('', as=omit) }}",
            "order": "{{ params.order | default('', as=omit) }}"
          }
        },
        "response": {
          "success_when": "$.status >= 200 and $.status < 300"
        }
      },
      "query_chunks": {
        "method": "POST",
        "path": "/api/agent/chunks/query",
        "body": {
          "template": {
            "start": "{{ params.start }}",
            "end": "{{ params.end }}",
            "chat_ids": "{{ params.chat_ids | default('', as=omit) }}",
            "chat_names": "{{ params.chat_names | default('', as=omit) }}",
            "chat_types": "{{ params.chat_types | default('', as=omit) }}",
            "sender_names": "{{ params.sender_names | default('', as=omit) }}",
            "included_only": "{{ params.included_only | default('', as=omit) }}",
            "text_query": "{{ params.text_query | default('', as=omit) }}",
            "limit": "{{ params.limit | default('', as=omit) }}",
            "cursor": "{{ params.cursor | default('', as=omit) }}",
            "order": "{{ params.order | default('', as=omit) }}",
            "include_content": "{{ params.include_content | default('', as=omit) }}"
          }
        },
        "response": {
          "success_when": "$.status >= 200 and $.status < 300"
        }
      },
      "summarize_range": {
        "method": "POST",
        "path": "/api/agent/summary",
        "body": {
          "template": {
            "start": "{{ params.start }}",
            "end": "{{ params.end }}",
            "chat_ids": "{{ params.chat_ids | default('', as=omit) }}",
            "chat_names": "{{ params.chat_names | default('', as=omit) }}",
            "chat_types": "{{ params.chat_types | default('', as=omit) }}",
            "sender_ids": "{{ params.sender_ids | default('', as=omit) }}",
            "sender_names": "{{ params.sender_names | default('', as=omit) }}",
            "sources": "{{ params.sources | default('', as=omit) }}",
            "included_only": "{{ params.included_only | default('', as=omit) }}",
            "text_query": "{{ params.text_query | default('', as=omit) }}",
            "limit": "{{ params.limit | default('', as=omit) }}",
            "cursor": "{{ params.cursor | default('', as=omit) }}",
            "order": "{{ params.order | default('', as=omit) }}",
            "prompt": "{{ params.prompt | default('', as=omit) }}",
            "include_messages": "{{ params.include_messages | default('', as=omit) }}"
          }
        },
        "response": {
          "success_when": "$.status >= 200 and $.status < 300"
        }
      }
    }
  }
}
