{
  "spec_version": "1.0",
  "id": "github_cli",
  "display_name": "GitHub CLI",
  "version": "1.0.0",
  "author": "agent-core team",
  "description": "GitHub API via the gh CLI. Supports listing repositories, listing issues, and creating issues using structured JSON output.",
  "credential_schema": {
    "fields": [
      {
        "name": "token",
        "type": "string",
        "secret": true,
        "required": true,
        "description": "GitHub personal access token (PAT) or fine-grained token. Also honors GITHUB_TOKEN if GH_TOKEN is not set."
      }
    ]
  },
  "requires": {
    "bins": ["gh"]
  },
  "actions": [
    {
      "name": "list_repos",
      "description": "List repositories for a user or organization.",
      "side_effect": "read",
      "input_schema": {
        "type": "object",
        "properties": {
          "owner": {
            "type": "string",
            "description": "Owner (user or org) to list repos for. Defaults to authenticated user when omitted."
          },
          "limit": {
            "type": "integer",
            "description": "Maximum number of repos to return (1-100). Defaults to 30."
          }
        }
      }
    },
    {
      "name": "list_issues",
      "description": "List issues in a repository.",
      "side_effect": "read",
      "input_schema": {
        "type": "object",
        "properties": {
          "repo": {
            "type": "string",
            "description": "Repository in owner/repo format (e.g. 'owner/repo')."
          },
          "limit": {
            "type": "integer",
            "description": "Maximum number of issues to return (1-100). Defaults to 30."
          }
        },
        "required": ["repo"]
      }
    },
    {
      "name": "create_issue",
      "description": "Create a new issue in a repository.",
      "side_effect": "write",
      "input_schema": {
        "type": "object",
        "properties": {
          "repo": {
            "type": "string",
            "description": "Repository in owner/repo format (e.g. 'owner/repo')."
          },
          "title": {
            "type": "string",
            "description": "Issue title."
          },
          "body": {
            "type": "string",
            "description": "Issue body/description."
          }
        },
        "required": ["repo", "title"]
      }
    }
  ],
  "backend": {
    "type": "cli",
    "bin": "gh",
    "timeout": 30,
    "env": {
      "GH_TOKEN": "{{ cred.token | default('', as=str) }}",
      "GITHUB_TOKEN": "{{ cred.token | default('', as=str) }}"
    },
    "commands": {
      "list_repos": {
        "description": "List repositories via gh repo list",
        "args": [
          "repo", "list",
          "--json", "name,url,visibility",
          "--owner", "{{ params.owner | default(\"\", as=str) }}",
          "--limit", "{{ params.limit | default(30, as=int) }}"
        ],
        "parse": {
          "type": "jsonpath",
          "path": "$"
        }
      },
      "list_issues": {
        "description": "List issues via gh issue list",
        "args": [
          "issue", "list",
          "--json", "title,number,state,url",
          "--repo", "{{ params.repo }}",
          "--limit", "{{ params.limit | default(30, as=int) }}"
        ],
        "parse": {
          "type": "jsonpath",
          "path": "$"
        }
      },
      "create_issue": {
        "description": "Create an issue via gh issue create",
        "args": [
          "issue", "create",
          "--json", "url,number",
          "--title", "{{ params.title }}",
          "--body", "{{ params.body | default('', as=str) }}",
          "--repo", "{{ params.repo }}"
        ],
        "parse": {
          "type": "jsonpath",
          "path": "$"
        }
      }
    }
  }
}