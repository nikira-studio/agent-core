      "description": "Create a new issue label in a company.",
      "side_effect": "write",
      "input_schema": {
        "type": "object",
        "required": ["company_id", "name"],
        "properties": {
          "company_id": {"type": "string", "description": "Paperclip company ID."},
          "name": {"type": "string", "description": "Label name."},
