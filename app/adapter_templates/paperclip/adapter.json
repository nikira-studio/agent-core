        "type": "object",
        "required": ["company_id", "skill_id"],
        "properties": {
          "company_id": {"type": "string", "description": "Paperclip company ID."},
          "skill_id": {"type": "string", "description": "Skill ID to update."}
        }
      }
    },
    {
      "name": "list_routines",
      "description": "List all routines in a company.",
      "side_effect": "read",
      "input_schema": {
        "type": "object",
        "required": ["company_id"],
