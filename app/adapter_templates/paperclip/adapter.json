    {
      "name": "upsert_issue_document",
      "description": "Create or update a document on an issue. Creates if absent, updates (with revision) if present.",
      "side_effect": "write",
      "input_schema": {
        "type": "object",
        "required": ["issue_id", "key", "format", "body"],
        "properties": {
          "issue_id": {"type": "string", "description": "Issue ID or identifier."},
          "key": {"type": "string", "description": "Document key, e.g. 'plan' or 'notes'."},
          "format": {"type": "string", "description": "Document format, typically 'markdown'."},
          "body": {"type": "string", "description": "Document body content."},
          "title": {"type": "string", "description": "Optional document title."},
          "change_summary": {"type": "string", "description": "Optional summary of what changed in this revision."},
          "base_revision_id": {"type": "string", "description": "Optional base revision ID for conflict detection."}
        }
      }
    },
    {
      "name": "list_issue_attachments",
      "description": "List file attachments on an issue.",
      "side_effect": "read",
      "input_schema": {
        "type": "object",
        "required": ["issue_id"],
        "properties": {
          "issue_id": {"type": "string", "description": "Issue ID or identifier."}
        }
      }
    }
  ],
